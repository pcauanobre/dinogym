generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER

  @@map("Role")
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String?          @unique
  cpf             String?          @unique
  passwordHash    String
  role            UserRole         @default(MEMBER)
  firstAccessDone Boolean          @default(false)
  photoBase64       String?          @db.Text
  routineTemplates  Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  machines          Machine[]
  sessions          WorkoutSession[]
  routineDays       RoutineDay[]

  @@map("users")
}

model Machine {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  name             String
  category         String
  photoBase64      String?           @db.Text
  currentPR        Float?
  isFavorite       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  entries          WorkoutEntry[]
  routineExercises RoutineExercise[]

  @@map("machines")
}

model RoutineDay {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  dayOfWeek Int
  label     String?
  exercises RoutineExercise[]

  @@unique([userId, dayOfWeek])
  @@map("routine_days")
}

model RoutineExercise {
  id           String     @id @default(cuid())
  routineDayId String
  routineDay   RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)
  machineId    String
  machine      Machine    @relation(fields: [machineId], references: [id])
  sets         Int        @default(3)
  reps         Int        @default(12)
  repsMax      Int?
  sortOrder    Int        @default(0)

  @@map("routine_exercises")
}

model WorkoutSession {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  date       DateTime       @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  duration   Int?
  dayRating  Int?
  nutrition  Int?
  finished   Boolean        @default(false)
  entries    WorkoutEntry[]

  @@map("workout_sessions")
}

model WorkoutEntry {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id])
  machineId  String
  machine    Machine        @relation(fields: [machineId], references: [id])
  weight     Float
  sets       Int?
  reps       Int?
  hitPR      Boolean        @default(false)
  previousPR Float?
  notes      String?
  setsData   String?        @db.Text
  comment    String?        @db.Text
  sortOrder  Int?
  createdAt  DateTime       @default(now())

  @@map("workout_entries")
}
